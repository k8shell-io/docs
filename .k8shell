blueprint:
  template: development
  resources:
    cpu: 16
    memory: 16Gi
  network:
    networkPolicyClass: system
  apps:
    vscode:
      enabled: false

  storages:
    ramdisk:
      enabled: true
      type: memory
      sizeLimit: 3Gi
      #path: !cel "'/home/' + user.username + '/' + metadata.repoName + '/node_modules'"
      path: /opt/ramdisk

  initScripts:
  - name: npm-init
    script: |
      mkdir -p /opt/ramdisk/npm-cache
      npm config set cache /opt/ramdisk/npm-cache --global
      cd $HOME/docs
      npm install --verbose

  - name: agents-setup
    script: |
      # setup agents
      mkdir -p $HOME/docs/.github/agents/
      ln -s /opt/shared/agents/consistency-check.agent.md $HOME/docs/.github/agents/consistency-check.agent.md
