blueprint:
  template: development
  resources:
    cpu: 16
    memory: 16Gi
  network:
    networkPolicyClass: system
  apps:
    vscode:
      enabled: false

  initScripts:
  - name: npm-init
    script: |
      # install dependencies
      cd $HOME/docs
      npm install --verbose

  - name: test-error
    script:
      sleep 4
      echo "error!"
      exit 1

  - name: agents-setup
    script: |
      # setup agents
      mkdir -p $HOME/docs/.github/agents/
      ln -s /opt/shared/agents/consistency-check.agent.md $HOME/docs/.github/agents/consistency-check.agent.md
